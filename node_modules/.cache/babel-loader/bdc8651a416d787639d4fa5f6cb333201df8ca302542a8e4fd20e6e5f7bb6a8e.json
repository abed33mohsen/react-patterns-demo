{"ast":null,"code":"import{useEffect,useState}from'react';export default function useTimedMessage(){let timeout=arguments.length>0&&arguments[0]!==undefined?arguments[0]:2200;const[message,setMessage]=useState('');useEffect(()=>{if(!message){return undefined;}const timerId=window.setTimeout(()=>{setMessage('');},timeout);return()=>window.clearTimeout(timerId);},[message,timeout]);return{message,setMessage,clearMessage:()=>setMessage('')};}","map":{"version":3,"names":["useEffect","useState","useTimedMessage","timeout","arguments","length","undefined","message","setMessage","timerId","window","setTimeout","clearTimeout","clearMessage"],"sources":["D:/React/src/hooks/useTimedMessage.js"],"sourcesContent":["import { useEffect, useState } from 'react';\n\nexport default function useTimedMessage(timeout = 2200) {\n  const [message, setMessage] = useState('');\n\n  useEffect(() => {\n    if (!message) {\n      return undefined;\n    }\n\n    const timerId = window.setTimeout(() => {\n      setMessage('');\n    }, timeout);\n\n    return () => window.clearTimeout(timerId);\n  }, [message, timeout]);\n\n  return {\n    message,\n    setMessage,\n    clearMessage: () => setMessage(''),\n  };\n}\n"],"mappings":"AAAA,OAASA,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAE3C,cAAe,SAAS,CAAAC,eAAeA,CAAA,CAAiB,IAAhB,CAAAC,OAAO,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,IAAI,CACpD,KAAM,CAACG,OAAO,CAAEC,UAAU,CAAC,CAAGP,QAAQ,CAAC,EAAE,CAAC,CAE1CD,SAAS,CAAC,IAAM,CACd,GAAI,CAACO,OAAO,CAAE,CACZ,MAAO,CAAAD,SAAS,CAClB,CAEA,KAAM,CAAAG,OAAO,CAAGC,MAAM,CAACC,UAAU,CAAC,IAAM,CACtCH,UAAU,CAAC,EAAE,CAAC,CAChB,CAAC,CAAEL,OAAO,CAAC,CAEX,MAAO,IAAMO,MAAM,CAACE,YAAY,CAACH,OAAO,CAAC,CAC3C,CAAC,CAAE,CAACF,OAAO,CAAEJ,OAAO,CAAC,CAAC,CAEtB,MAAO,CACLI,OAAO,CACPC,UAAU,CACVK,YAAY,CAAEA,CAAA,GAAML,UAAU,CAAC,EAAE,CACnC,CAAC,CACH","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}