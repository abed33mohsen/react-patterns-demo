{"ast":null,"code":"import{useEffect,useState}from'react';import{POSTS_ENDPOINT}from'./constants';export default function usePosts(){const[posts,setPosts]=useState([]);const[isLoading,setIsLoading]=useState(true);useEffect(()=>{setIsLoading(true);fetch(POSTS_ENDPOINT).then(response=>response.json()).then(data=>{setPosts(data);setIsLoading(false);}).catch(()=>{setPosts([]);setIsLoading(false);});},[]);return{posts,isLoading};}","map":{"version":3,"names":["useEffect","useState","POSTS_ENDPOINT","usePosts","posts","setPosts","isLoading","setIsLoading","fetch","then","response","json","data","catch"],"sources":["D:/React/src/components/Posts/usePosts.js"],"sourcesContent":["import { useEffect, useState } from 'react';\nimport { POSTS_ENDPOINT } from './constants';\n\nexport default function usePosts() {\n  const [posts, setPosts] = useState([]);\n  const [isLoading, setIsLoading] = useState(true);\n\n  useEffect(() => {\n    setIsLoading(true);\n\n    fetch(POSTS_ENDPOINT)\n      .then((response) => response.json())\n      .then((data) => {\n        setPosts(data);\n        setIsLoading(false);\n      })\n      .catch(() => {\n        setPosts([]);\n        setIsLoading(false);\n      });\n  }, []);\n\n  return {\n    posts,\n    isLoading,\n  };\n}\n"],"mappings":"AAAA,OAASA,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAC3C,OAASC,cAAc,KAAQ,aAAa,CAE5C,cAAe,SAAS,CAAAC,QAAQA,CAAA,CAAG,CACjC,KAAM,CAACC,KAAK,CAAEC,QAAQ,CAAC,CAAGJ,QAAQ,CAAC,EAAE,CAAC,CACtC,KAAM,CAACK,SAAS,CAAEC,YAAY,CAAC,CAAGN,QAAQ,CAAC,IAAI,CAAC,CAEhDD,SAAS,CAAC,IAAM,CACdO,YAAY,CAAC,IAAI,CAAC,CAElBC,KAAK,CAACN,cAAc,CAAC,CAClBO,IAAI,CAAEC,QAAQ,EAAKA,QAAQ,CAACC,IAAI,CAAC,CAAC,CAAC,CACnCF,IAAI,CAAEG,IAAI,EAAK,CACdP,QAAQ,CAACO,IAAI,CAAC,CACdL,YAAY,CAAC,KAAK,CAAC,CACrB,CAAC,CAAC,CACDM,KAAK,CAAC,IAAM,CACXR,QAAQ,CAAC,EAAE,CAAC,CACZE,YAAY,CAAC,KAAK,CAAC,CACrB,CAAC,CAAC,CACN,CAAC,CAAE,EAAE,CAAC,CAEN,MAAO,CACLH,KAAK,CACLE,SACF,CAAC,CACH","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}